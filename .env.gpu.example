# GPU deployment env template. Copy to .env.gpu and fill in real values.
# .env.gpu is gitignored — never commit real hosts or credentials.

# AWS
AWS_PUBLIC_HOST=<your-public-host-or-ip>

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_DETECTIONS=doorbell-detections

# YOLO Worker
MODEL_PATH=yolov8n.pt
CONFIDENCE=0.35
OUTPUT_FPS=15

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_DB=doorbell
POSTGRES_USER=doorbell
POSTGRES_PASSWORD=<choose-a-strong-password>

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Java Backend
JAVA_SERVER_PORT=8080

WEBRTC_ICE_HOST=<your-public-host-or-ip>
DEVICE=cuda
